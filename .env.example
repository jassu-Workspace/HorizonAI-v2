# Frontend
VITE_API_PROXY_BASE=https://your-domain.vercel.app/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Core backend
# Set NODE_ENV=production in your hosting platform (for example Vercel project env),
# not in local Vite .env files.
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://www.your-domain.com

# Internal auth (required for secure internal API calls)
INTERNAL_SIGNING_KEY=replace_with_long_random_secret
INTERNAL_SIGNATURE_TTL_MS=30000
INTERNAL_API_BASE_URL=https://your-domain.vercel.app

# NVIDIA model key mapping
NVIDIA_API_KEY_1=key_for_z_ai_glm47
NVIDIA_API_KEY_2=key_for_meta_llama_31_405b
NVIDIA_API_KEY_3=key_for_mistral_7b
NVIDIA_API_KEY=

# AI controls and quotas
NVIDIA_KEY_RATE_LIMIT_COOLDOWN_MS=65000
NVIDIA_KEY_ERROR_COOLDOWN_MS=8000
NVIDIA_KEY_MAX_RETRIES=6
AI_MAX_MESSAGES=20
AI_MAX_MESSAGE_LENGTH=4000
AI_MAX_INPUT_TOKENS=6000
AI_MAX_OUTPUT_TOKENS=1200
AI_DAILY_TOKEN_QUOTA=50000
AI_HOURLY_TOKEN_QUOTA=10000
AI_RL_IP_5M=40
AI_RL_USER_5M=30
AI_RL_DEVICE_5M=25
AI_ABUSE_SCORE_THROTTLE=50
AI_ABUSE_SCORE_BLOCK=70
AI_ABUSE_SCORE_BAN=90

# Redis / Upstash
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_TOKEN=

# Optional integrations
NEWSDATA_API_KEY=
NEWSDATA_API_KEY_BACKUP=
VIRUSTOTAL_API_KEY=
CLAMAV_HOST=
NEWS_RL_IP_5M=50
